@model PrezentacioniSloj.Models.NoviVozacModel
@{
    ViewData["Title"] = "Novi Vozac";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="text-center">Dodaj novog vozaca</h2>

        <form asp-action="NoviVozac" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Ime"></label>
                <input asp-for="Ime" class="form-control" />
                <span asp-validation-for="Ime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Prezime"></label>
                <input asp-for="Prezime" class="form-control" />
                <span asp-validation-for="Prezime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BrojTelefona"></label>
                <input asp-for="BrojTelefona" class="form-control" placeholder="0612345678" />
                <span asp-validation-for="BrojTelefona" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Dodaj</button>
            <a asp-action="Vozaci" class="btn btn-secondary">Nazad</a>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}