@model PrezentacioniSloj.Models.NoviKorisnikModel
@{
    ViewData["Title"] = "Novi Korisnik";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="text-center">Dodaj novog korisnika</h2>

        <form asp-action="NoviKorisnik" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Ime"></label>
                <input asp-for="Ime" class="form-control" />
                <span asp-validation-for="Ime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Prezime"></label>
                <input asp-for="Prezime" class="form-control" />
                <span asp-validation-for="Prezime" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="KorisnickoIme"></label>
                <input asp-for="KorisnickoIme" class="form-control" />
                <span asp-validation-for="KorisnickoIme" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Lozinka"></label>
                <input asp-for="Lozinka" type="password" class="form-control" />
                <span asp-validation-for="Lozinka" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TipKorisnika"></label>
                <select asp-for="TipKorisnika" class="form-control">
                    <option value="">Izaberite tip...</option>
                    <option value="Admin">Admin</option>
                    <option value="Dispečer">Dispecer</option>
                    <option value="Klijent">Klijent</option>
                </select>
                <span asp-validation-for="TipKorisnika" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Dodaj</button>
            <a asp-action="Korisnici" class="btn btn-secondary">Nazad</a>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}