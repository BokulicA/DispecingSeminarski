@using System.Data
@model PrezentacioniSloj.Models.DodeliNalogModel
@{
    ViewData["Title"] = "Dodeli Nalog";
    var vozaci = ViewBag.Vozaci as DataSet;
    var kamioni = ViewBag.Kamioni as DataSet;
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="text-center">Dodeli nalog #@ViewBag.NalogID</h2>
        <form asp-controller="Dispecer" asp-action="DodeliNalog" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="NalogID" value="@ViewBag.NalogID" />

            <div class="form-group mb-3">
                <label asp-for="VozacID"></label>
                <select asp-for="VozacID" class="form-control">
                    <option value="">-- Izaberite vozaca --</option>
                    @if (vozaci != null && vozaci.Tables.Count > 0)
                    {
                        @foreach (DataRow r in vozaci.Tables[0].Rows)
                        {
                            <option value="@r["VozacID"]">@r["Ime"] @r["Prezime"] (@r["BrojTelefona"])</option>
                        }
                    }
                </select>
                <span asp-validation-for="VozacID" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Registracija"></label>
                <select asp-for="Registracija" class="form-control">
                    <option value="">-- Izaberite kamion --</option>
                    @if (kamioni != null && kamioni.Tables.Count > 0)
                    {
                        @foreach (DataRow r in kamioni.Tables[0].Rows)
                        {
                            <option value="@r["Registracija"]">@r["Registracija"] - @r["Marka"] (@r["Nosivost"]t)</option>
                        }
                    }
                </select>
                <span asp-validation-for="Registracija" class="text-danger"></span>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary">Dodeli</button>
                <a class="btn btn-secondary" asp-controller="Dispecer" asp-action="KreiraniNalozi">Nazad</a>
            </div>
        </form>
    </div>
</div>